# Auto-detect text files and normalize line endings
* text=auto

# Swift files
*.swift text diff=swift

# C files (upstream library code)
*.c text diff=c
*.h text diff=c

# Upstream C library in Sources should be marked as vendored
Sources/libevent/** linguist-vendored

# Generated config files
Sources/libevent/src/evconfig-private.h        linguist-generated
Sources/libevent/include/event2/event-config.h linguist-generated

# Vendor/development directories
Vendor/**                   export-ignore linguist-vendored
.build/**                   export-ignore linguist-vendored
.github/**                  export-ignore linguist-vendored
.swiftpm/**                 export-ignore linguist-vendored
.specify/**                 export-ignore linguist-vendored
.windsurf/**                export-ignore linguist-vendored
specs/**                    export-ignore linguist-vendored

# CI/CD and tooling configs
Dockerfile                  export-ignore
.dockerignore               export-ignore
subtree.yaml                export-ignore

# Git and editor files
.gitignore                  export-ignore
.gitmodules                 export-ignore
.DS_Store                   export-ignore

# Package lockfile (not needed for library consumers)
Package.resolved            export-ignore linguist-generated